---
const { title } = Astro.props;
const siteTitle = title ? `${title} — Benfazeja` : 'Benfazeja';
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Playfair+Display:opsz,wght@5..120,400;5..120,600&display=swap"
			rel="stylesheet"
		/>

		<meta name="generator" content={Astro.generator} />
		<title>{siteTitle}</title>
	</head>

	<body>
		<main class="editorial">
			<slot />
		</main>
	</body>
</html>

<style>
	:root {
		--bg: #fdfbf7;
		--text: #1a1a1a;
		--muted: rgba(26, 26, 26, 0.78);
		--rule: rgba(26, 26, 26, 0.14);
	}

	html,
	body {
		margin: 0;
		padding: 0;
		background: var(--bg);
		color: var(--text);
	}

	body {
		font-family: 'Playfair Display', ui-serif, Georgia, Cambria, 'Times New Roman', Times, serif;
		-webkit-font-smoothing: antialiased;
		text-rendering: optimizeLegibility;
	}

	.editorial {
		max-width: 65ch; /* mancha gráfica ideal para leitura longa */
		margin: 0 auto;
		padding: clamp(1.25rem, 3vw, 2.5rem);
	}

	/* Tipografia base */
	p {
		font-size: 1.05rem;
		line-height: 1.75;
		margin: 1.2em 0;
		letter-spacing: -0.006em;
		font-feature-settings: 'liga' 1, 'kern' 1;
	}

	h1,
	h2 {
		font-weight: 600;
		letter-spacing: -0.02em;
		line-height: 1.15;
		font-feature-settings: 'liga' 1, 'kern' 1;
	}

	h1 {
		font-size: clamp(2.1rem, 4vw, 3.25rem);
		margin: 0;
	}

	.subtitle {
		margin: 0.35rem 0 2.2rem;
		font-size: 1.2rem;
		line-height: 1.55;
		color: var(--muted);
		letter-spacing: -0.01em;
	}

	.rule {
		height: 1px;
		background: var(--rule);
		margin: 1.15rem 0 0;
	}

	h2 {
		font-size: 1.6rem;
		margin: 2.4rem 0 0.9rem;
	}

	section {
		scroll-margin-top: 2rem;
	}

	header {
		padding-top: clamp(1.25rem, 4vw, 2.5rem);
	}
</style>

